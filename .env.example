# Backend
HOST=0.0.0.0
PORT=8080
DATABASE_URL=postgres://user:password@localhost:5432/day_planner
DATABASE_MAX_CONNECTIONS=5

# Ideavibes platform auth. The platform injects production values.
SELF_URL=http://localhost:5173
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_example_token
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# Legacy runtime fallback only. New code should use the mctai_session cookie.
JWT_SECRET=replace-with-a-long-random-string

# Frontend
VITE_API_BASE_URL=http://localhost:8080
